{
  "name": "opendlp-frontend",
  "version": "1.0.0",
  "description": "Frontend assets for OpenDLP",
  "scripts": {
    "build:sass": "sass src/scss:static/css --load-path=node_modules --style=compressed",
    "watch:sass": "sass src/scss:static/css --load-path=node_modules --watch",
    "build:backoffice": "npx tailwindcss -i ./static/backoffice/src/main.css -o ./static/backoffice/dist/main.css --minify",
    "watch:backoffice": "npx tailwindcss -i ./static/backoffice/src/main.css -o ./static/backoffice/dist/main.css --watch",
    "build:js": "esbuild static/backoffice/js/src/html-editor.js --bundle --minify --format=iife --sourcemap --outfile=static/backoffice/js/dist/html-editor.js",
    "watch:js": "esbuild static/backoffice/js/src/html-editor.js --bundle --sourcemap --format=iife --outfile=static/backoffice/js/dist/html-editor.js --watch",
    "build": "npm run build:sass && npm run build:backoffice && npm run build:js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/montserrat": "^5.2.8",
    "@lezer/highlight": "^1.2.3",
    "codemirror": "^6.0.2",
    "govuk-frontend": "^5.14.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "sass": "^1.101.0",
    "tailwindcss": "^3.4.0"
  }
}
